  </div>

  <div id="main-app">

    <div class="app-header">
      <div>
        <div class="header-badge">서구청 마스터 권한</div>
        <h2>홍석기 센터장님 👋</h2>
      </div>
      <div class="bell-btn" onclick="toast('새로운 행정 알림이 3건 있습니다.')">
        <i style="font-style:normal;">🔔</i>
        <span class="badge-dot">3</span>
      </div>
    </div>

    <div class="tab-content no-scroll">

      <div id="tab-dashboard" class="view-section active">

